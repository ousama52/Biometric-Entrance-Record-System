# ------------------------------------------------------------------
# .gitignore — Fingerprint Entry Record System
# Covers Visual Studio / .NET Framework, NuGet, and Arduino artifacts.
# ------------------------------------------------------------------

# --- Visual Studio / build outputs ---
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
build/
*.dll
*.exe
*.pdb
*.cache

# --- Visual Studio IDE / user state ---
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vsidx
UpgradeLog*.htm
_UpgradeReport_Files/
Backup*/

# --- NuGet packages (restored via `nuget restore` / MSBuild -t:Restore) ---
# The packages folder is machine-generated; it is intentionally not tracked.
packages/
*.nupkg
!**/packages/build/

# --- Installer (Visual Studio Installer Projects, *.vdproj) outputs ---
*.msi
setup.exe

# --- OS / misc ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tmp
*.bak

# --- Arduino build cache (if compiled locally with arduino-cli) ---
arduino/**/build/
