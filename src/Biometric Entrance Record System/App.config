<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <appSettings>
        <!-- The application uses an embedded SQLite database file (entrancerecord.db)
             created automatically next to the executable. No server is required.
             This value is informational; the actual path is resolved at runtime in Db.vb. -->
        <add key="connectionString" value="Data Source=entrancerecord.db;Version=3;" />
    </appSettings>
</configuration>
